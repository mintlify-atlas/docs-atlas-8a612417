  "keyFeatures": [
    "Multi-provider quota monitoring (Gemini, Claude, OpenAI, Antigravity, Kiro, Copilot)",
    "Real-time dashboard with visual progress bars",
    "One-click CLIProxyAPI proxy control (start/stop)",
    "System tray integration for quick access",
    "Auto-download and setup for CLIProxyAPI",
    "Dark/Light theme support",
    "Multilingual support (7 languages)",
    "Cross-platform desktop app (Windows, macOS, Linux)",
    "Auto-update functionality"
  ],
  "publicApiSurface": [
    "start_cli_proxy(exe_path) - Start CLI Proxy server",
    "stop_cli_proxy() - Stop CLI Proxy server",
    "is_cli_proxy_running() - Check proxy status",
    "download_and_extract_proxy(url, target_dir) - Download and extract proxy binary",
    "find_alternate_proxy_exe(current_exe_path, target_version) - Find alternate proxy executable",
    "check_proxy_version() - Check proxy version",
    "set_run_in_background(enabled) - Configure background mode",
    "open_external_url(url) - Open URL in browser",
    "AuthService.login(credentials) - Authenticate with CLIProxyAPI",
    "QuotaService.fetchQuota(provider, authFile) - Fetch quota for provider",
    "OAuthService.initiateOAuth(provider, projectId) - Start OAuth flow",
    "ConfigService.getServerInfo() - Get server version info",
    "UsageService.fetchUsageStats() - Fetch usage statistics",
    "LogsService.fetchLogs() - Fetch proxy logs"
  ]
